---
import Layout from '../layouts/Layout.astro';
import LibraryExplorer from '../components/LibraryExplorer.astro';
import ChatSidebar from '../components/ChatSidebar';
import AIStudyButton from '../components/AIStudyButton.jsx';
---

<Layout title="Biblioteca de Recursos">
	<div slot="sidebar-left" class="flex-1 p-4 space-y-6">
		<div>
			<h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Tu Progreso</h3>
			<div class="space-y-4">
				<div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3">
					<p class="text-[10px] text-indigo-600 font-bold uppercase mb-1">Curso Actual</p>
					<p class="text-xs font-bold text-indigo-900 leading-tight">Dietética y Nutrición Humana (FP)</p>
					<div class="mt-2 h-1.5 bg-indigo-200 rounded-full">
						<div class="h-full bg-indigo-600 rounded-full" style="width: 45%;"></div>
					</div>
				</div>
			</div>
		</div>

		<nav class="space-y-1">
			<h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Categorías</h3>
			<a href="#" class="flex items-center justify-between p-2 rounded-lg bg-medical-green-50 text-medical-green-700 font-bold text-xs">
				<span>Todos los Libros</span>
				<span class="bg-medical-green-100 px-1.5 py-0.5 rounded text-[10px]">12</span>
			</a>
			<a href="#" class="flex items-center justify-between p-2 rounded-lg text-slate-600 hover:bg-slate-50 transition-colors text-xs">
				<span>Bioquímica</span>
				<span class="bg-slate-100 px-1.5 py-0.5 rounded text-[10px]">4</span>
			</a>
		</nav>
	</div>

	<div class="p-6">
		<header class="mb-8 flex items-center justify-between">
			<div>
				<h1 class="text-3xl font-bold text-slate-800 tracking-tight">
					Biblioteca Académica
				</h1>
				<p class="text-slate-500 text-sm mt-1">Explora tu material de estudio y consulta con el Agente Alquimia.</p>
			</div>
			
			<AIStudyButton client:load />
		</header>
		
		<LibraryExplorer />
	</div>

	<div slot="sidebar-right" class="flex-1 overflow-hidden">
		<ChatSidebar client:load />
	</div>
</Layout>
